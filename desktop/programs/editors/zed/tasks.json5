[
  {
    "label": "workspace: open kitty terminal",
    "command": "open -a kitty file://$ZED_DIRNAME",
    "use_new_terminal": false,
    "reveal": "never"
  },
  {
    "label": "workspace: open with lazygit",
    "command": "open -a kitty git://$ZED_WORKTREE_ROOT",
    "use_new_terminal": false,
    "reveal": "never"
  },
  {
    "label": "workspace: open with fork",
    "command": "open -a fork file://$ZED_DIRNAME",
    "use_new_terminal": false,
    "reveal": "never"
  }
]
